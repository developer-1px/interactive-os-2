      "types": "./dist-lib/ui/menu-list.d.ts"
    },
    "./ui/disclosure-group": {
      "import": "./dist-lib/ui/disclosure-group.js",
      "types": "./dist-lib/ui/disclosure-group.d.ts"
    }
  },
  "files": [
    "dist-lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsup",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
