{
  "name": "interactive-os",
  "version": "0.1.0",
  "type": "module",
  "description": "Keyboard-first ARIA framework with plugin architecture for React",
  "license": "MIT",
  "keywords": [
    "aria",
    "keyboard",
    "accessibility",
    "react",
    "headless",
    "treegrid",
    "undo-redo"
  ],
  "sideEffects": false,
  "exports": {
    "./core/types": {
      "import": "./dist-lib/core/types.js",
      "types": "./dist-lib/core/types.d.ts"
    },
    "./core/normalized-store": {
      "import": "./dist-lib/core/normalized-store.js",
      "types": "./dist-lib/core/normalized-store.d.ts"
    },
    "./core/command-engine": {
      "import": "./dist-lib/core/command-engine.js",
      "types": "./dist-lib/core/command-engine.d.ts"
    },
    "./plugins/core": {
      "import": "./dist-lib/plugins/core.js",
      "types": "./dist-lib/plugins/core.d.ts"
    },
    "./plugins/history": {
      "import": "./dist-lib/plugins/history.js",
      "types": "./dist-lib/plugins/history.d.ts"
    },
    "./plugins/crud": {
      "import": "./dist-lib/plugins/crud.js",
      "types": "./dist-lib/plugins/crud.d.ts"
    },
    "./plugins/clipboard": {
      "import": "./dist-lib/plugins/clipboard.js",
      "types": "./dist-lib/plugins/clipboard.d.ts"
