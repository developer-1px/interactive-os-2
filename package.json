    "./hooks/use-keyboard": {
      "import": "./dist-lib/hooks/use-keyboard.js",
      "types": "./dist-lib/hooks/use-keyboard.d.ts"
    },
    "./components/aria": {
      "import": "./dist-lib/components/aria.js",
      "types": "./dist-lib/components/aria.d.ts"
    },
    "./ui/tree-grid": {
      "import": "./dist-lib/ui/tree-grid.js",
      "types": "./dist-lib/ui/tree-grid.d.ts"
