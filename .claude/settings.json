{
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/logAgentOps.mjs",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ]
  }
}
